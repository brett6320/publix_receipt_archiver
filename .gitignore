# Playwright persistent browser profile (contains your logged-in session!)
.publix_profile/

# All generated/downloaded data: raw receipts, parsed CSVs, PDFs, markdown,
# captures, fetch summaries — and credentials.json / api_headers.json /
# api_request.json. Never commit any of it.
data/

# Generated receipt output, wherever it lands (belt-and-suspenders if the output
# dir is relocated outside data/). No output is checked in: markdown, csv, json.
output/
**/output/
*.csv
receipts/*.md
markdown/

# Credentials / captured requests (belt-and-suspenders if data/ is relocated)
**/credentials.json
**/api_headers.json
**/api_request.json
**/web_users.json
*.curl

# All PDFs (receipt exports may contain card digits) and any exported receipt JSON.
*.pdf
publix_receipts*.json

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# macOS
.DS_Store
