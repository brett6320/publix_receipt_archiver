# Docker Compose environment for the Publix Receipt Archiver.
# Copy to .env (git-ignored) and fill in the values you need:
#   cp .env.example .env
# Compose reads .env automatically. The web service works with none of these
# set; the email-poller service needs the R2 + Cloudflare Queue values (or you
# can configure those in the admin UI instead — Collect tab → Email ingestion).

# ---- Web app ---------------------------------------------------------------
# Host port for the web UI.
PORT=8000
# Pin a published image tag for the poller (default: latest).
IMAGE_TAG=latest
# Set to 1 when serving over HTTPS (directly or behind a proxy) so the session
# cookie is marked Secure.
# PUBLIX_WEB_HTTPS=1
# Web session lifetime in seconds (default 12h).
# PUBLIX_SESSION_TTL=43200
# Label shown in authenticator apps when enrolling TOTP.
# PUBLIX_AUTH_ISSUER=Publix Receipt Archiver

# ---- Email ingestion poller (Cloudflare) -----------------------------------
# See cloudflare/README.md for how to obtain these. All optional if you instead
# save them in the admin UI (stored in data/email_config.json, shared via ./data).

# How often the poller pulls the queue, in seconds (default 300 = 5 min).
PUBLIX_EMAIL_POLL_INTERVAL=300

# Cloudflare R2 (S3-compatible) — where the Worker stores raw .eml objects.
PUBLIX_R2_ACCOUNT_ID=
PUBLIX_R2_BUCKET=publix-receipts
PUBLIX_R2_ACCESS_KEY_ID=
PUBLIX_R2_SECRET_ACCESS_KEY=
PUBLIX_R2_PREFIX=receipts/
# Optional: full S3 endpoint (derived from the account id if left blank).
# PUBLIX_R2_ENDPOINT=

# Cloudflare Queue — the poller pulls references from here and acks them.
PUBLIX_CF_QUEUE_ID=
# API token with Queues read/write (Account → Queues → Edit).
PUBLIX_CF_API_TOKEN=
